# ── Backend ──────────────────────────────────────────────────────
# PostgreSQL connection string (from Neon.tech or DigitalOcean)
# Leave empty to use in-memory database (development only)
ConnectionStrings__DefaultConnection=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/faithflow?sslmode=require

# JWT — generate a strong random secret (at least 32 chars)
JwtSettings__Secret=replace-with-a-strong-random-secret-at-least-32-chars
JwtSettings__Issuer=FaithFlowAPI
JwtSettings__Audience=FaithFlowClients
JwtSettings__ExpiryMinutes=60

# Google Gemini AI
GoogleAI__ApiKey=your-gemini-api-key

# CORS — comma-separated list of allowed frontend origins
CorsSettings__Origins=https://your-app.vercel.app

# ── Frontend (Vite) ───────────────────────────────────────────────
# Set to your DigitalOcean App Platform backend URL after deploying
VITE_API_URL=https://faithflow-api-xxxxx.ondigitalocean.app/api
VITE_SIGNALR_URL=https://faithflow-api-xxxxx.ondigitalocean.app

# ── GitHub Actions Secrets (set these in repo Settings → Secrets) ─
# DIGITALOCEAN_ACCESS_TOKEN — from cloud.digitalocean.com/account/api/tokens
# DO_APP_ID                 — from `doctl apps list` after first deploy
# VERCEL_TOKEN              — from vercel.com/account/tokens
# PRODUCTION_API_URL        — same as VITE_API_URL above
# PRODUCTION_SIGNALR_URL    — same as VITE_SIGNALR_URL above
